{
  "crons": [
    {
      "path": "/api/analytics/summarize",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/photos/backfill",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/generate-websites",
      "schedule": "*/10 * * * *"
    }
  ],
  "functions": {
    "api/search/resolve-share.js": {
      "memory": 1024
    }
  },
  "rewrites": [
    { "source": "/employee/explainer", "destination": "/employee/explainer.html" },
    { "source": "/employee/welcome", "destination": "/employee/welcome.html" },
    { "source": "/employee/login", "destination": "/employee/login.html" },
    { "source": "/employee", "destination": "/employee/admin.html" },
    { "source": "/employee/search", "destination": "/employee/admin.html" },
    { "source": "/employee/admin", "destination": "/employee/admin.html" },
    { "source": "/employee/saved", "destination": "/employee/admin.html" },
    { "source": "/employee/messages", "destination": "/employee/admin.html" },
    { "source": "/mipagina", "destination": "/customer/index.html" },
    { "source": "/mipagina/:nombre", "destination": "/customer/index.html" },
    { "source": "/demo/:id", "destination": "/demo/index.html" },
    { "source": "/ver/:id", "destination": "/preview/index.html" },
    { "source": "/planes/:id", "destination": "/planes/index.html" },
    { "source": "/checkout/confirmacion", "destination": "/checkout/confirmacion.html" },
    { "source": "/checkout/:id", "destination": "/checkout/index.html" },
    { "source": "/sitio/:slug", "destination": "/api/sitio/serve?slug=:slug" },
    { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
    { "source": "/editorial", "destination": "/editorial.html" },
    { "source": "/about", "destination": "/about.html" },
    {
      "source": "/:path*",
      "destination": "/api/sitio/serve",
      "has": [{ "type": "host", "value": "(?!.*ahoratengopagina\\.com)(?!.*vercel\\.app)(?!localhost).*" }]
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
